---
const clinicName = 'Vågsbygd legesenter';

const navItems = [
  { label: 'Hjem', href: '/' },
  { label: 'Ansatte', href: '/ansatte', active: true },
  { label: 'Priser', href: '/priser' },
  { label: 'Skjema', href: '/skjema' },
  { label: 'Informasjon', href: '/informasjon' },
  { label: 'Kontakt', href: '/kontakt' },
];

const staff = [
  {
    name: 'Dr. Zelda Hyrule',
    role: 'Fastlege og spesialist i allmennmedisin',
    text: 'Rolig i møte med både feber, frysninger og pasienter som har funnet rare urter i skogen.',
  },
  {
    name: 'Dr. Link Linkesen',
    role: 'Fastlege',
    text: 'Snakker lite, lytter godt og har mistenkelig høy treffsikkerhet med reflekshammeren.',
  },
  {
    name: 'Impa Sheikah',
    role: 'Helsesekretær',
    text: 'Holder oversikt over timebøker, prøvesvar og alle som prøver å snike seg forbi køsystemet.',
  },
  {
    name: 'Purah Lab',
    role: 'Laboratorium',
    text: 'Tar prøver, analyserer tall og sier “interessant” på en måte som gjør alle litt nervøse.',
  },
  {
    name: 'Mipha Zora',
    role: 'Sykepleier',
    text: 'Trygg, varm og sannsynligvis den personen du helst vil møte når dagen ble litt for bossfight.',
  },
  {
    name: 'Beedle Beedlesen',
    role: 'Resepsjon',
    text: 'Hjelper med praktiske spørsmål, betaling og retninger uten å selge deg fem ekstra piler.',
  },
];
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>Ansatte - {clinicName}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-shell" aria-label="Hovedmeny">
        <a class="brand" href="/">
          <img class="brand-logo" src="/logo-title.png" alt={clinicName} />
        </a>

        <div class="nav-links">
          {
            navItems.map((item) => (
              <a href={item.href} class:list={['nav-link', item.active && 'is-active']} aria-current={item.active ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
        </div>
      </nav>
    </header>

    <main class="page-main">
      <section class="page-hero">
        <div class="content-wrap">
          <p class="section-kicker">Ansatte</p>
          <h1>Folkene bak disken</h1>
          <p>
            Her er et lite testlag for Vågsbygd legesenter. Tenk fastlegekontor, bare med litt mer
            Hyrule-energi og færre potter i venterommet.
          </p>
        </div>
      </section>

      <section class="content-section">
        <div class="content-wrap staff-grid">
          {
            staff.map((person) => (
              <article class="staff-card">
                <span class="staff-mark" aria-hidden="true">+</span>
                <h2>{person.name}</h2>
                <p class="staff-role">{person.role}</p>
                <p>{person.text}</p>
              </article>
            ))
          }
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>© 2026 Hyrule Health Guild. Designet av Link Corporation.</p>
    </footer>
  </body>
</html>

<style>
  :root {
    --color-primary: #12224b;
    --color-brand-sand: #b8a37e;
    --color-brand-cream: #f7f4ec;
    --color-brand-ink: #4b3f2d;
    --color-green: #0d6b57;
    --color-mint: #d8f0e7;
    --color-surface: #ffffff;
    --shadow-soft: 0 16px 36px rgb(18 34 75 / 12%);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--color-brand-cream);
    color: var(--color-primary);
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-size: 18px;
    line-height: 1.55;
  }

  a {
    color: inherit;
  }

  .site-header {
    background: var(--color-brand-cream);
    border-bottom: 1px solid rgb(184 163 126 / 26%);
  }

  .nav-shell,
  .content-wrap {
    margin: 0 auto;
    max-width: 1120px;
  }

  .nav-shell {
    align-items: center;
    display: flex;
    gap: 2rem;
    justify-content: space-between;
    min-height: 96px;
    padding: 1rem 1.5rem;
  }

  .brand-logo {
    display: block;
    height: clamp(2.4rem, 5vw, 3.6rem);
    width: auto;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: flex-end;
  }

  .nav-link {
    color: var(--color-brand-ink);
    display: inline-flex;
    font-size: 1.25rem;
    font-weight: 700;
    padding-bottom: 0.3rem;
    position: relative;
    text-decoration: none;
  }

  .nav-link::after,
  .section-kicker::after {
    background: var(--color-brand-sand);
    border-radius: 999px;
    bottom: 0;
    content: '';
    height: 3px;
    left: 0;
    position: absolute;
  }

  .nav-link::after {
    opacity: 0;
    transform: scaleX(0.65);
    transform-origin: left;
    transition: opacity 160ms ease, transform 160ms ease;
    width: 100%;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .nav-link.is-active::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .page-hero {
    background: linear-gradient(135deg, var(--color-brand-cream), #ffffff);
    padding: 4rem 1.5rem 2rem;
  }

  .section-kicker {
    color: var(--color-brand-ink);
    display: inline-flex;
    font-size: 1.2rem;
    font-weight: 900;
    margin: 0 0 1rem;
    padding-bottom: 0.35rem;
    position: relative;
  }

  .section-kicker::after {
    width: 68%;
  }

  h1 {
    color: var(--color-brand-ink);
    font-size: clamp(3rem, 7vw, 5.8rem);
    font-weight: 900;
    line-height: 0.95;
    margin: 0 0 1rem;
    max-width: 760px;
  }

  .page-hero p:not(.section-kicker) {
    color: #5f6470;
    font-size: 1.2rem;
    font-weight: 700;
    max-width: 680px;
  }

  .content-section {
    background: white;
    padding: 3.5rem 1.5rem 5rem;
  }

  .staff-grid {
    display: grid;
    gap: 1.4rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .staff-card {
    background: #fbfefd;
    border: 1px solid rgb(13 107 87 / 13%);
    border-radius: 1rem;
    box-shadow: var(--shadow-soft);
    padding: 1.4rem;
  }

  .staff-mark {
    align-items: center;
    background: var(--color-mint);
    border-radius: 50%;
    color: var(--color-green);
    display: inline-flex;
    font-size: 1.4rem;
    font-weight: 900;
    height: 36px;
    justify-content: center;
    margin-bottom: 1rem;
    width: 36px;
  }

  .staff-card h2 {
    color: var(--color-green);
    font-size: 1.45rem;
    line-height: 1.1;
    margin: 0 0 0.45rem;
  }

  .staff-role {
    color: var(--color-brand-ink);
    font-weight: 900;
    margin-bottom: 0.8rem;
  }

  .staff-card p {
    color: #52605d;
    font-weight: 650;
    margin: 0;
  }

  .site-footer {
    background: var(--color-brand-ink);
    color: rgb(247 244 236 / 86%);
    font-weight: 700;
    padding: 1.25rem 1rem;
    text-align: center;
  }

  .site-footer p {
    margin: 0;
  }

  @media (max-width: 760px) {
    body {
      font-size: 16px;
    }

    .nav-shell {
      align-items: flex-start;
      flex-direction: column;
      gap: 1rem;
      min-height: auto;
    }

    .nav-links {
      gap: 1rem;
      justify-content: flex-start;
    }

    .staff-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
