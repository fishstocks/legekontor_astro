  vaccine:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 2 9 11"/><path d="m13 4 7 7-3 3-7-7Z"/><path d="m9 11-6 6 2 2 1-1 1 1 2-2-1-1 1-1 1 1 2-2Z"/></svg>',
  world:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18Z"/></svg>',
  book:
