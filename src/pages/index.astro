---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Hjemmeside for Vågsbygd legesenter med timebestilling, reseptfornyelse, aktuelt og kontaktinformasjon."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700&family=Baloo+2:wght@600;800&display=swap"
      rel="stylesheet"
    />
    <title>Hjem - {clinicName}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-shell" aria-label="Hovedmeny">
        <a class="brand" href="/">
          <img class="brand-logo" src="/logo-title.png" alt={clinicName} />
        </a>

        <div class="nav-links">
          {
            navItems.map((item) => (
              <a href={item.href} class:list={['nav-link', item.active && 'is-active']} aria-current={item.active ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
        </div>
      </nav>
    </header>

    <main>
      <section class="hero-section">
        <div class="content-wrap hero-content">
          <p class="hero-eyebrow">Velkommen til</p>
          <h1>Vågsbygd<br />legesenter</h1>

          <div class="hero-buttons" aria-label="Snarveier">
            <a class="hero-button hero-button-primary" href="https://minhelse.helsenorge.no/fastlegen/bestill-time">
              Timeavtale
            </a>
            <a class="hero-button" href="https://minhelse.helsenorge.no/fastlegen/forny-resept">
              Resepter
            </a>
          </div>
        </div>
      </section>

      <section class="quickfacts-section" aria-label="Praktisk informasjon">
        <div class="quickfacts-grid">
          {
            quickFacts.map((fact, index) => (
              <div class="quickfact-item">
                {index > 0 && (
                  <div class="quickfact-divider" aria-hidden="true">
                    <span></span>
                  </div>
                )}
                <div class:list={['quickfact-icon', fact.accent && 'is-accent']} set:html={icons[fact.icon]} />
                <h3>{fact.title}</h3>
                <p>{fact.text}</p>
                {fact.href && (
                  <a class="quickfact-link" href={fact.href}>
                    Gå til Helsenorge
                  </a>
                )}
              </div>
            ))
          }
        </div>
      </section>

      <section class="contact-method-section" aria-label="Slik når du oss">
        <div class="content-wrap contact-method-card">
          <p class="contact-method-label">Slik når du oss</p>
          <p>
            All kommunikasjon med legesenteret går via
            <a href="https://www.helsenorge.no/" target="_blank" rel="noreferrer">Helsenorge</a>
            eller telefon. Bruk Helsenorge for timebestilling, reseptfornyelse, e-konsultasjon og
            administrative henvendelser.
          </p>
        </div>
      </section>

      <div class="phone-pill-wrap">
        <a class="phone-pill is-closed" href="tel:+4712345678">
          <span aria-hidden="true">☎</span>
          Telefon - stengt
        </a>
      </div>

      <section class="notice-section">
        <div class="content-wrap">
          <article class="notice-card" aria-label="Viktig beskjed">
            <p class="notice-title">Heisen i ustand</p>
            <p>
              Dette er et testvarsel. Her går det an å informere pasientene om viktige beskjeder i
              en spesifisert tidsperiode.
            </p>
            <time datetime="2025-02-13">13. februar 2025</time>
          </article>
        </div>
      </section>

      <section class="about-section" aria-labelledby="about-heading">
        <div class="content-wrap about-layout">
          <div class="about-content">
            <p class="section-kicker">Om oss</p>
            <h2 id="about-heading">Vågsbygd legesenter</h2>

            <p>
              Vågsbygd legesenter ligger sentralt i Hyrule, et par raske steg fra nærmeste stall og
              akkurat langt nok unna Death Mountain til at resepsjonen slipper lavaskader i
              venterommet.
            </p>

            <p>
              Vi er et fastlegekontor med modige behandlere, helsesekretærer med bedre oversikt enn
              et fullstendig kart og nok plaster til en middels krevende bossfight. Enten du trenger
              time, reseptfornyelse eller en vurdering av hvorfor du plutselig hører bossmusikk,
              møter vi deg med faglighet og hjertecontainer-varme.
            </p>

            <ul class="about-list" aria-label="Kort om legesenteret">
              <li>Allmennlegekontor for Hylians, Gorons og slitne eventyrere</li>
              <li>Null toleranse for uregistrerte cursed potions</li>
              <li>Fastleger, helsesekretærer og høy rupee-moral</li>
            </ul>
          </div>

          <div class="map-card image-card">
            <img src="/sykehus.png" alt="Illustrasjon av Vågsbygd legesenter" loading="lazy" />
          </div>
        </div>
      </section>

      <section class="services-section" aria-labelledby="services-heading">
        <div class="content-wrap">
          <div class="services-header">
            <h2 id="services-heading">
              <span class="services-title-dark">Våre</span>
              <span class="services-title-accent">tjenester</span>
            </h2>
            <p>Vågsbygd legesenter tilbyr alle vanlige fastlegetjenester.</p>
          </div>

          <div class="services-grid">
            {
              services.map((service) => (
                <article class="service-item">
                  <div class="service-icon" set:html={icons[service.icon]} />
                  <h3>{service.title}</h3>
                  <div class="service-triforce" aria-hidden="true">
                    <span></span>
                    <span></span>
                  </div>
                  <p>{service.text}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="info-section" aria-labelledby="info-heading">
        <div class="content-wrap">
          <article class="info-card">
            <div class="info-emergency">
              <p class="info-label">Ved øyeblikkelig hjelp utenfor åpningstid</p>
              <p>
                Ring Hyrule legevakt på <a href="tel:116117">116117</a>, eller bruk
                <a href="tel:113">113</a> ved akutte og livstruende tilstander. Hvis du hører
                bossmusikk og mister tre hjerter på rad, ikke vent til mandag.
              </p>
            </div>

            <div class="info-content">
              <h2 id="info-heading">Viktig informasjon</h2>
              <p>
                Her er det viktigste de fleste pasienter trenger raskt. Vaksiner, bytte av fastlege
                og andre nyttige lenker ligger samlet på informasjonssiden.
              </p>

              <div class="info-quick-grid">
                <div class="info-quick-item">
                  <span>Akutt time</span>
                  <strong>Ring samme dag fra kl. 08:00</strong>
                </div>
                <div class="info-quick-item">
                  <span>Tolk</span>
                  <strong>Gi beskjed ved bestilling av time</strong>
                </div>
                <div class="info-quick-item">
                  <span>Blodprøver</span>
                  <strong>Må avtales med lege eller resepsjon</strong>
                </div>
                <div class="info-quick-item">
                  <span>Attester</span>
                  <strong>Bestilles via legekontoret</strong>
                </div>
                <div class="info-quick-item">
                  <span>Prøvesvar</span>
                  <strong>Kontakt legekontoret eller se Helsenorge dersom tilgjengelig</strong>
                </div>
                <div class="info-quick-item">
                  <span>Avbestilling</span>
                  <strong>Avbestill senest 24 timer før</strong>
                </div>
              </div>

              <a class="info-link" href="/informasjon">Se vaksiner og nyttige lenker</a>
            </div>
          </article>
        </div>
      </section>

      <section class="switch-section" aria-labelledby="switch-heading">
        <div class="content-wrap switch-layout">
          <div class="switch-content">
            <p class="section-kicker">Bytte fastlege</p>
            <h2 id="switch-heading">Vil du bytte til oss?</h2>
            <p>
              Du kan bytte fastlege via Helsenorge. Søk opp Vågsbygd Torv Legesenter AS og følg
              stegene der.
            </p>
            <p>
              Husk at du selv må gi beskjed til legekontoret du bytter fra om at journalen skal
              oversendes til ny fastlege. Dette skjer ikke automatisk.
            </p>
            <a
              class="switch-link"
              href="https://tjenester.helsenorge.no/bytte-fastlege?searchquery=V%C3%A5gsbygd%20Torv%20Legesenter%20AS&searchquerytype=legekontor"
              target="_blank"
              rel="noreferrer"
            >
              Åpne Helsenorge
            </a>
          </div>
        </div>
      </section>

      <section class="useful-section" aria-labelledby="useful-heading">
        <div class="content-wrap useful-wrap">
          <div class="useful-block blood-test-block">
            <h2 id="useful-heading">Dine blodprøver</h2>
            <p>
              Har du fått tatt blodprøver som er sendt til Fürst laboratorium, kan du logge inn for
              å se resultatene dine.
            </p>
          </div>

          <a class="blood-test-panel" href="https://www.furstpasient.no/" target="_blank" rel="noreferrer">
            <div class="blood-test-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M12 3s-6 5.7-6 10a6 6 0 0 0 12 0c0-4.3-6-10-6-10Z" />
              </svg>
            </div>
            <div>
              <strong>Fürst pasientportal</strong>
              <small>Logg inn og se dine blodprøvesvar</small>
            </div>
            <span aria-hidden="true">→</span>
          </a>

          <p class="section-kicker useful-links-kicker">Nyttige lenker</p>

          <div class="official-link-grid" aria-label="Offentlige helselenker">
            {
              usefulLinks.map((link) => (
                <a class="official-link-card" href={link.href} target="_blank" rel="noreferrer">
                  <div class="official-link-icon" set:html={icons[link.icon]} />
                  <div class="official-link-text">
                    <strong>{link.title}</strong>
                    <small>{link.text}</small>
                  </div>
                  <span class="official-link-arrow" aria-hidden="true">→</span>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <section class="contact-map-section" aria-label="Åpningstider og kart">
        <div class="contact-map-layout">
          <aside class="contact-panel">
            <div class="contact-block">
              <h2>Åpningstider</h2>
              <div class="hours-list">
                <div class="hours-row">
                  <span>Legekontor</span>
                  <strong>Man-fre 08:00-15:00</strong>
                </div>
                <div class="hours-row">
                  <span>Telefon</span>
                  <strong>Man-fre 08:30-14:30</strong>
                </div>
                <div class="hours-row">
                  <span>Laboratorium</span>
                  <strong>Man-fre 08:15-14:00</strong>
                </div>
                <div class="hours-row">
                  <span>Helg</span>
                  <strong>Stengt</strong>
                </div>
              </div>
            </div>

            <div class="contact-block">
              <h2>Kontakt oss</h2>
              <div class="contact-lines">
                <p>Vardåsveien 69, 4637 Kristiansand</p>
                <p><a href="tel:+4738128844">+47 38 12 88 44</a></p>
              </div>
            </div>

            <div class="contact-note">
              <span>Quest log</span>
              <a href="/personvern">Personvern og cookies for Vågsbygd legesenter</a>
            </div>
          </aside>

          <div class="contact-map">
            <iframe
              title="Kart til Vågsbygd legesenter"
              src="https://www.google.com/maps?q=Vard%C3%A5sveien%2069%2C%204637%20Kristiansand&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>
