    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>',
  mail:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v14H4z"/><path d="m4 7 8 6 8-6"/></svg>',
  heartbeatStrip:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12h4l2-4 3 8 2-6 2 2h5"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>',
  message:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.7a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.4 8.4 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/></svg>',
  heartbeat:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"/><path d="M4 13h4l2-4 4 8 2-4h4"/></svg>',
  stethoscope:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3v5a4 4 0 0 0 8 0V3"/><path d="M10 16a6 6 0 0 0 12 0v-2"/><path d="M22 14a2 2 0 1 0-4 0 2 2 0 0 0 4 0Z"/><path d="M4 3h2M14 3h2"/></svg>',
  microscope:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 18h8M3 22h18M8 18a6 6 0 0 0 6-6"/><path d="m9 4 6 6"/><path d="m7 6 4-4 6 6-4 4Z"/><path d="M14 12h4v4"/></svg>',
  bandage:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m10 10 4 4"/><path d="M8.5 15.5 3.8 10.8a4 4 0 0 1 5.7-5.7l9.4 9.4a4 4 0 0 1-5.7 5.7l-4.7-4.7Z"/><path d="m14.5 8.5-6 6"/><path d="M9.5 9.5h.01M11.5 11.5h.01M12.5 8.5h.01M14.5 10.5h.01"/></svg>',
  activity:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12h4l2-7 4 14 2-7h6"/><path d="M17 4a4 4 0 0 1 4 4"/></svg>',
  testTube:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 2h8"/><path d="M14 2v7.5l4.3 7.4A3.4 3.4 0 0 1 15.4 22H6.6a3.4 3.4 0 0 1-2.9-5.1L8 9.5V2"/><path d="M6 16h10"/></svg>',
  phone:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.8a2 2 0 0 1-.5 2.1L8 9.9a16 16 0 0 0 6.1 6.1l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z"/></svg>',
  school:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m22 10-10-5-10 5 10 5 10-5Z"/><path d="M6 12v5c3 2 9 2 12 0v-5"/><path d="M22 10v6"/></svg>',
  route:
