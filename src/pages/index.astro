---
// Page data lives here so you can edit text, links, and images without hunting
// through the HTML. Later, these arrays can move into separate files/components.
const clinicName = 'Vågsbygd legesenter';

const navItems = [
  { label: 'Hjem', href: '/', active: true },
  { label: 'Ansatte', href: '/ansatte' },
  { label: 'Priser', href: '/priser' },
  { label: 'Skjema', href: '/skjema' },
  { label: 'Informasjon', href: '/informasjon' },
  { label: 'Kontakt', href: '/kontakt' },
];

const quickFacts = [
  {
    icon: 'heartbeatStrip',
    title: 'Akutt time',
    text: 'Ring samme dag fra kl. 08:00. Ved livstruende tilstander, ring 113.',
    accent: true,
  },
  {
    icon: 'clock',
    title: 'Åpningstider',
    text: 'Man-fre 08:00-15:00. Telefon 08:30-14:30. Helg stengt.',
  },
  {
    icon: 'message',
    title: 'E-konsultasjon',
    text: 'Nettbasert skriftlig konsultasjon, samme egenandel som vanlig legetime.',
    href: 'https://minhelse.helsenorge.no/fastlegen/e-konsultasjon',
  },
  {
    icon: 'mail',
    title: 'Kontakt legekontoret',
    text: 'Administrative henvendelser, for eksempel bestilling av drosje.',
    href: 'https://minhelse.helsenorge.no/fastlegen/kontakt-legekontoret',
  },
];

const usefulLinks = [
  {
    icon: 'route',
    title: 'Pasientreiser',
    text: 'Reise til og fra behandling',
    href: 'https://www.helsenorge.no/rettigheter/pasientreiser/',
  },
  {
    icon: 'building',
    title: 'NAV',
    text: '55 55 33 33',
    href: 'https://www.nav.no/',
  },
  {
    icon: 'shield',
    title: 'Helfo',
    text: 'Refusjon og frikort',
    href: 'https://www.helfo.no/',
  },
  {
    icon: 'cross',
    title: 'Helsedirektoratet',
    text: 'Nasjonale helseråd',
    href: 'https://www.helsedirektoratet.no/',
  },
  {
    icon: 'vaccine',
    title: 'Folkehelseinstituttet',
    text: 'Vaksiner og smittevern',
    href: 'https://www.fhi.no/',
  },
  {
    icon: 'world',
    title: 'Helsenorge',
    text: 'Dine helsetjenester',
    href: 'https://www.helsenorge.no/',
  },
  {
    icon: 'book',
    title: 'Helsebiblioteket',
    text: 'Pasientinformasjon',
    href: 'https://www.helsebiblioteket.no/',
  },
];

const services = [
  {
    icon: 'heartbeat',
    title: 'Akutt helsehjelp',
    text: 'Alle fastlegene ved Vågsbygd legesenter yter akutt helsehjelp for sine pasienter. Hver dag har vi åpne akutt-timer. Dersom din lege er borte akkurat den dagen er vi vikar for hverandre.',
  },
  {
    icon: 'stethoscope',
    title: 'Sykdomsoppfølging',
    text: 'Ved et fastlegekontor får du en fastlege som følger deg i et sykdomsforløp. Vi leser epikrise fra sykehuset, følger opp på kontroller og har som mål å yte trygg og god oppfølging, over tid.',
  },
  {
    icon: 'microscope',
    title: 'Celleprøve',
    text: 'Alle legene ved Vågsbygd legesenter utfører celleprøve som anbefalt nasjonalt, og oppfordrer våre pasienter til å følge disse anbefalingene.',
  },
  {
    icon: 'bandage',
    title: 'Små-kirurgi',
    text: 'Vi har to fullt utstyrte skiftestuer. Vi fjerner store og små føflekker, fettkuler, vorter og sjenerende utvekster. Ved skader syr vi store og små sår.',
  },
  {
    icon: 'activity',
    title: 'EKG, spirometri og 24t BT',
    text: 'Vi har utstyr til hjerteprøver, pusteprøver og kan også følge blodtrykket ditt over 24 timer, dersom det er grunn til dette.',
  },
  {
    icon: 'testTube',
    title: 'Lab-tjenester',
    text: 'Vi tilbyr hurtigprøver ved infeksjon, diabetes, urinplager og INR. I tillegg tar vi vanlige blodprøver som sendes for videre analyse ved sykehuset.',
  },
  {
    icon: 'phone',
    title: 'Tilgjengelighet',
    text: 'Vi tilbyr timebestilling direkte i legens timebok, for å gjøre det enklest mulig for deg som pasient. I tillegg gjør det telefonen mer tilgjengelig for akutte tilstander.',
  },
  {
    icon: 'school',
    title: 'Høy kompetanse',
    text: 'Alle legene ved Vågsbygd legesenter er ferdige spesialister i allmennmedisin, en 5-årig etterutdanning. Vi tilstreber høy faglig kompetanse ved vårt legesenter.',
  },
];

// Small SVG helper keeps the action cards readable without depending on a large icon library.
