  building:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 21V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v16"/><path d="M14 9h4a2 2 0 0 1 2 2v10"/><path d="M9 21v-4M4 21h16M9 9h.01M9 13h.01M9 5h.01"/></svg>',
  shield:
