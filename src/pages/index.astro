---
// Page data lives here so you can edit text, links, and images without hunting
// through the HTML. Later, these arrays can move into separate files/components.
const clinicName = 'Vågsbygd legesenter';

const navItems = [
  { label: 'Hjem', href: '/', active: true },
  { label: 'Ansatte', href: '/ansatte' },
  { label: 'Priser', href: '/priser' },
  { label: 'Skjema', href: '/skjema' },
  { label: 'Informasjon', href: '/informasjon' },
  { label: 'Kontakt', href: '/kontakt' },
];

const patientActions = [
  {
    title: 'Bestill time',
    text: 'Bestill time på Helsenorge, eller ring oss.',
    href: 'https://minhelse.helsenorge.no/fastlegen/bestill-time',
    icon: 'calendar',
  },
  {
    title: 'Forny resept',
    text: 'Forny resepten din på Helsenorge.',
    href: 'https://minhelse.helsenorge.no/fastlegen/forny-resept',
    icon: 'capsule',
  },
  {
    title: 'E-konsultasjon',
    text: 'Nettbasert skriftlig konsultasjon. Du betaler egenandel som ved vanlig legetime.',
    href: 'https://minhelse.helsenorge.no/fastlegen/e-konsultasjon',
    icon: 'person',
  },
  {
    title: 'Kontakt legekontoret',
    text: 'Administrative henvendelser til legekontoret, for eksempel bestilling av drosje.',
    href: 'https://minhelse.helsenorge.no/fastlegen/kontakt-legekontoret',
    icon: 'mail',
  },
];

// Small SVG helper keeps the action cards readable without depending on a large icon library.
const icons = {
  calendar:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2v3M17 2v3M4 9h16M6 4h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/><path d="m9 14 2 2 4-4"/></svg>',
  capsule:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m10.5 20.5 10-10a4.24 4.24 0 0 0-6-6l-10 10a4.24 4.24 0 0 0 6 6Z"/><path d="m8.5 10.5 5 5"/></svg>',
  person:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>',
  mail:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v14H4z"/><path d="m4 7 8 6 8-6"/></svg>',
};
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Hjemmeside for Vågsbygd legesenter med timebestilling, reseptfornyelse, aktuelt og kontaktinformasjon."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>Hjem - {clinicName}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-shell" aria-label="Hovedmeny">
        <a class="brand" href="/">
          <img class="brand-logo" src="/logo-title.png" alt={clinicName} />
        </a>

        <div class="nav-links">
          {
            navItems.map((item) => (
              <a href={item.href} class:list={['nav-link', item.active && 'is-active']} aria-current={item.active ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
        </div>
      </nav>
    </header>

    <main>
      <section class="hero-section">
        <div class="content-wrap hero-content">
          <p class="hero-eyebrow">Velkommen til</p>
          <h1>Vågsbygd<br />legesenter</h1>

          <div class="hero-buttons" aria-label="Snarveier">
            <a class="hero-button hero-button-primary" href="https://minhelse.helsenorge.no/fastlegen/bestill-time">
              Timeavtale
            </a>
            <a class="hero-button" href="https://minhelse.helsenorge.no/fastlegen/forny-resept">
              Resepter
            </a>
          </div>
        </div>
      </section>

      <section class="action-section" aria-label="Digitale tjenester">
        <div class="content-wrap">
          <div class="action-grid" aria-label="Digitale tjenester">
            {
              patientActions.map((action) => (
                <a class="action-card" href={action.href}>
                  <span class="action-icon" set:html={icons[action.icon]} />
                  <span>
                    <strong>{action.title}</strong>
                    <small>{action.text}</small>
                  </span>
                </a>
              ))
            }
          </div>

          <a class="phone-pill is-closed" href="tel:+4712345678">
            <span aria-hidden="true">☎</span>
            Telefon - stengt
          </a>
        </div>
      </section>

      <section class="notice-section">
        <div class="content-wrap">
          <article class="notice-card" aria-label="Viktig beskjed">
            <p class="notice-title">Heisen i ustand</p>
            <p>
              Dette er et testvarsel. Her går det an å informere pasientene om viktige beskjeder i
              en spesifisert tidsperiode.
            </p>
            <time datetime="2025-02-13">13. februar 2025</time>
          </article>
        </div>
      </section>

      <section class="info-section" aria-labelledby="info-heading">
        <div class="content-wrap">
          <article class="info-card">
            <div class="info-emergency">
              <p class="info-label">Ved øyeblikkelig hjelp utenfor åpningstid</p>
              <p>
                Ring Hyrule legevakt på <a href="tel:116117">116117</a>, eller bruk
                <a href="tel:113">113</a> ved akutte og livstruende tilstander. Hvis du hører
                bossmusikk og mister tre hjerter på rad, ikke vent til mandag.
              </p>
            </div>

            <div class="info-content">
              <h2 id="info-heading">Viktig informasjon</h2>
              <p>
                Her er det viktigste de fleste pasienter trenger raskt. Vaksiner, bytte av fastlege
                og andre nyttige lenker ligger samlet på informasjonssiden.
              </p>

              <div class="info-quick-grid">
                <div class="info-quick-item">
                  <span>Akutt time</span>
                  <strong>Ring samme dag fra kl. 08:00</strong>
                </div>
                <div class="info-quick-item">
                  <span>Tolk</span>
                  <strong>Gi beskjed ved bestilling av time</strong>
                </div>
                <div class="info-quick-item">
                  <span>Blodprøver</span>
                  <strong>Må avtales med lege eller resepsjon</strong>
                </div>
                <div class="info-quick-item">
                  <span>Attester</span>
                  <strong>Bestilles via legekontoret</strong>
                </div>
                <div class="info-quick-item">
                  <span>Prøvesvar</span>
                  <strong>Kontakt legekontoret eller se Helsenorge dersom tilgjengelig</strong>
                </div>
                <div class="info-quick-item">
                  <span>Avbestilling</span>
                  <strong>Avbestill senest 24 timer før</strong>
                </div>
              </div>

              <a class="info-link" href="/informasjon">Se vaksiner og nyttige lenker</a>
            </div>
          </article>
        </div>
      </section>

      <section class="about-section" aria-labelledby="about-heading">
        <div class="content-wrap about-layout">
          <div class="about-content">
            <p class="section-kicker">Om oss</p>
            <h2 id="about-heading">Vågsbygd legesenter</h2>

            <p>
              Vågsbygd legesenter ligger sentralt i Hyrule, et par raske steg fra nærmeste stall og
              akkurat langt nok unna Death Mountain til at resepsjonen slipper lavaskader i
              venterommet.
            </p>

            <p>
              Vi er et fastlegekontor med modige behandlere, helsesekretærer med bedre oversikt enn
              et fullstendig kart og nok plaster til en middels krevende bossfight. Enten du trenger
              time, reseptfornyelse eller en vurdering av hvorfor du plutselig hører bossmusikk,
              møter vi deg med faglighet og hjertecontainer-varme.
            </p>

            <ul class="about-list" aria-label="Kort om legesenteret">
              <li>Allmennlegekontor for Hylians, Gorons og slitne eventyrere</li>
              <li>Null toleranse for uregistrerte cursed potions</li>
              <li>Fastleger, helsesekretærer og høy rupee-moral</li>
            </ul>
          </div>

          <div class="map-card image-card">
            <img src="/sykehus.png" alt="Illustrasjon av Vågsbygd legesenter" loading="lazy" />
          </div>
        </div>
      </section>

      <section class="contact-map-section" aria-label="Åpningstider og kart">
        <div class="contact-map-layout">
          <aside class="contact-panel">
            <div class="contact-block">
              <h2>Åpningstider</h2>
              <div class="hours-list">
                <div class="hours-row">
                  <span>Legekontor</span>
                  <strong>Man-fre 08:00-15:00</strong>
                </div>
                <div class="hours-row">
                  <span>Telefon</span>
                  <strong>Man-fre 08:30-14:30</strong>
                </div>
                <div class="hours-row">
                  <span>Laboratorium</span>
                  <strong>Man-fre 08:15-14:00</strong>
                </div>
                <div class="hours-row">
                  <span>Helg</span>
                  <strong>Stengt</strong>
                </div>
              </div>
            </div>

            <div class="contact-block">
              <h2>Kontakt oss</h2>
              <div class="contact-lines">
                <p>Vardåsveien 69, 4637 Kristiansand</p>
                <p><a href="tel:+4738128844">+47 38 12 88 44</a></p>
              </div>
            </div>

            <div class="contact-note">
              <span>Quest log</span>
              <a href="/personvern">Personvern og cookies for Vågsbygd legesenter</a>
            </div>
          </aside>

          <div class="contact-map">
            <iframe
              title="Kart til Vågsbygd legesenter"
              src="https://www.google.com/maps?q=Vard%C3%A5sveien%2069%2C%204637%20Kristiansand&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>
        © 2026 Hyrule Health Guild. Vågsbygd legesenter™, Master Sword Medical Systems™ og alle
        rupee-relaterte venteromsavgifter er designet av Link Corporation. Ingen potter ble knust
        under utviklingen.
      </p>
    </footer>
  </body>
</html>

<style>
  :root {
    --color-primary: #12224b;
    --color-brand-sand: #b8a37e;
    --color-brand-cream: #f7f4ec;
    --color-brand-ink: #4b3f2d;
    --color-primary-soft: #dce8f4;
    --color-heading-band: #c9dceb;
    --color-surface: #ffffff;
    --color-action-panel: #d8f0e7;
    --color-action-accent: #1f8a70;
    --color-action-accent-strong: #0d6b57;
    --color-action-card: #d8f0e7;
    --color-muted: #667085;
    --color-border: #d9e2ec;
    --color-warning: #fff0f0;
    --color-footer: #d8dee7;
    --shadow-soft: 0 16px 36px rgb(18 34 75 / 12%);
    --action-card-overlap: 6rem;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #f6f8fb;
    color: var(--color-primary);
    font-family: 'Source Sans 3', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 18px;
    line-height: 1.55;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-header {
    background: var(--color-brand-cream);
    border-bottom: 1px solid rgb(184 163 126 / 26%);
  }

  .nav-shell {
    align-items: center;
    display: flex;
    gap: 2rem;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1120px;
    min-height: 96px;
    padding: 1rem 1.5rem;
  }

  .brand {
    align-items: center;
    display: inline-flex;
    text-decoration: none;
  }

  .brand-logo {
    display: block;
    height: clamp(2.4rem, 5vw, 3.6rem);
    object-fit: contain;
    width: auto;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: flex-end;
  }

  .nav-link {
    color: var(--color-brand-ink);
    display: inline-flex;
    font-size: 1.25rem;
    font-weight: 500;
    padding-bottom: 0.3rem;
    position: relative;
    text-decoration: none;
  }

  .nav-link::after {
    background: var(--color-brand-sand);
    border-radius: 999px;
    bottom: 0;
    content: '';
    height: 3px;
    left: 0;
    opacity: 0;
    position: absolute;
    transform: scaleX(0.65);
    transform-origin: left;
    transition: opacity 160ms ease, transform 160ms ease;
    width: 100%;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .nav-link.is-active::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .hero-section {
    align-items: center;
    background-image: linear-gradient(rgb(18 73 105 / 54%), rgb(18 73 105 / 48%)),
      url('https://images3.alphacoders.com/710/thumb-1920-710798.jpg');
    background-position: center;
    background-size: cover;
    color: white;
    display: flex;
    min-height: 680px;
    padding: 5rem 1rem 7.5rem;
  }

  .content-wrap {
    margin: 0 auto;
    max-width: 1120px;
  }

  .hero-content {
    width: 100%;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(4.5rem, 7vw, 8.4rem);
    font-weight: 800;
    line-height: 0.92;
    margin-bottom: 2rem;
    max-width: 760px;
    text-align: left;
  }

  .hero-eyebrow {
    font-size: clamp(1rem, 1.8vw, 1.35rem);
    font-style: italic;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.1rem;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-button {
    align-items: center;
    background: white;
    border-radius: 999px;
    box-shadow: 0 10px 20px rgb(0 0 0 / 16%);
    color: #101828;
    display: inline-flex;
    font-size: 1.25rem;
    font-weight: 800;
    justify-content: center;
    min-width: 180px;
    padding: 1rem 2.2rem;
    text-decoration: none;
  }

  .hero-button-primary {
    background: #1498d5;
    color: white;
  }

  .action-section {
    background: linear-gradient(
      to bottom,
      transparent 0,
      rgb(255 255 255 / 52%) calc(var(--action-card-overlap) * 0.45),
      var(--color-surface) var(--action-card-overlap)
    );
    margin-top: calc(-1 * var(--action-card-overlap));
    padding: 0 1rem 3rem;
    position: relative;
    z-index: 2;
  }

  .action-section .content-wrap {
    position: relative;
  }

  .notice-section {
    background: var(--color-surface);
    padding: 0 1rem 4rem;
  }

  .notice-card {
    background: var(--color-warning);
    border-radius: 1.5rem;
    box-shadow: var(--shadow-soft);
    margin: 0 auto;
    max-width: 760px;
    padding: 1.5rem;
    text-align: center;
  }

  .notice-title {
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  time {
    color: var(--color-muted);
    display: inline-block;
    font-size: 0.9rem;
  }

  .info-section {
    background: var(--color-surface);
    padding: 0 1rem 4.5rem;
  }

  .info-card {
    background: #fbfefd;
    border: 1px solid rgb(13 107 87 / 12%);
    border-radius: 1.5rem;
    box-shadow: 0 18px 44px rgb(8 79 80 / 10%);
    overflow: hidden;
  }

  .info-emergency {
    background: #0d6b57;
    color: white;
    padding: 1.5rem clamp(1.5rem, 4vw, 2.5rem);
  }

  .info-label {
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    margin-bottom: 0.45rem;
    text-transform: uppercase;
  }

  .info-emergency p:last-child {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0;
  }

  .info-emergency a {
    color: white;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.18em;
  }

  .info-content {
    padding: clamp(1.75rem, 4vw, 2.7rem);
  }

  .info-content h2 {
    color: #063b33;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .info-content p,
  .info-content li {
    color: #39556b;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.55;
  }

  .info-quick-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1.8rem;
  }

  .info-quick-item {
    background: rgb(216 240 231 / 48%);
    border: 1px solid rgb(13 107 87 / 12%);
    border-radius: 0.85rem;
    display: grid;
    gap: 0.25rem;
    padding: 0.95rem 1rem;
  }

  .info-quick-item span {
    color: var(--color-green);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .info-quick-item strong {
    color: #063b33;
    font-size: 1.02rem;
    line-height: 1.2;
  }

  .info-link {
    background: var(--color-green);
    border-radius: 999px;
    color: white;
    display: inline-flex;
    font-weight: 900;
    margin-top: 1.6rem;
    padding: 0.8rem 1.15rem;
    text-decoration: none;
  }

  .action-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: 2rem;
  }

  .action-card {
    align-items: stretch;
    background: var(--color-action-card);
    border-radius: 1.5rem;
    border: 1px solid rgb(13 107 87 / 14%);
    box-shadow: 0 18px 40px rgb(31 138 112 / 16%);
    display: grid;
    grid-template-columns: minmax(110px, 30%) 1fr;
    min-height: 154px;
    overflow: hidden;
    text-decoration: none;
  }

  .action-card:hover,
  .action-card:focus-visible {
    outline: 3px solid rgb(21 154 138 / 24%);
    outline-offset: 4px;
  }

  .action-icon {
    align-items: center;
    background: var(--color-action-card);
    display: flex;
    justify-content: center;
    padding: 1.5rem;
  }

  .action-icon :global(svg) {
    fill: none;
    height: 4.5rem;
    stroke: var(--color-action-accent-strong);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
    width: 4.5rem;
  }

  .action-card span:last-child {
    align-self: center;
    padding: 1.5rem;
  }

  .action-card strong {
    color: #063b33;
    display: block;
    font-size: 1.35rem;
    line-height: 1.2;
    margin-bottom: 0.65rem;
  }

  .action-card small {
    color: #245f55;
    display: block;
    font-size: 1rem;
  }

  .phone-pill {
    align-items: center;
    background: var(--color-surface);
    border: 2px solid #ad1f2d;
    border-radius: 999px;
    box-shadow: var(--shadow-soft);
    display: flex;
    font-weight: 700;
    gap: 0.75rem;
    margin: 1rem auto 0;
    max-width: max-content;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
  }

  .section-heading {
    background: var(--color-heading-band);
    padding: 3rem 1rem 1.5rem;
    text-align: center;
  }

  .section-heading h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0;
  }

  .white-section {
    background: var(--color-surface);
    padding: 3.5rem 1rem;
  }

  .about-section {
    background: var(--color-surface);
    padding: 4rem 1rem;
  }

  .about-layout {
    align-items: stretch;
    display: grid;
    gap: 3rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.1fr);
  }

  .about-content {
    max-width: 560px;
  }

  .section-kicker {
    color: var(--color-brand-ink);
    display: inline-flex;
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    padding-bottom: 0.35rem;
    position: relative;
  }

  .section-kicker::after {
    background: var(--color-brand-sand);
    border-radius: 999px;
    bottom: 0;
    content: '';
    height: 3px;
    left: 0;
    position: absolute;
    width: 68%;
  }

  .about-content h2 {
    color: #050505;
    font-size: clamp(2.2rem, 4.2vw, 3.4rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.96;
    margin-bottom: 1.7rem;
    max-width: 460px;
  }

  .about-content p {
    color: #63666b;
    font-size: clamp(1rem, 1.35vw, 1.18rem);
    font-weight: 600;
    line-height: 1.52;
    margin-bottom: 1.35rem;
  }

  .about-list {
    color: #63666b;
    display: grid;
    font-size: clamp(0.95rem, 1.25vw, 1.08rem);
    font-weight: 700;
    gap: 0.7rem;
    list-style: none;
    margin: 1.8rem 0 0;
    padding: 0;
  }

  .about-list li {
    align-items: center;
    display: grid;
    gap: 1rem;
    grid-template-columns: 34px 1fr;
  }

  .about-list li::before {
    align-items: center;
    background: #1498d5;
    border-radius: 50%;
    color: white;
    content: '✓';
    display: inline-flex;
    font-size: 1.1rem;
    font-weight: 900;
    height: 24px;
    justify-content: center;
    width: 24px;
  }

  .map-card {
